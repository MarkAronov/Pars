echo "Running pre-push checks..."

# Backend checks
if [ -d "backend-nestjs" ]; then
  echo "→ backend-nestjs: type check"
  (cd backend-nestjs && bunx tsc --noEmit) || exit 1

  echo "→ backend-nestjs: tests (skipped locally — requires Docker/Testcontainers, runs in CI)"
  # (cd backend-nestjs && bun test) || exit 1

  echo "→ backend-nestjs: build"
  (cd backend-nestjs && bun run build) || exit 1
fi

if [ -d "backend-express" ]; then
  echo "→ backend-express: type check"
  (cd backend-express && bunx tsc --noEmit) || exit 1

  echo "→ backend-express: tests (skipped locally — requires Docker/Testcontainers, runs in CI)"
  # (cd backend-express && bun test) || exit 1

  echo "→ backend-express: build"
  (cd backend-express && bun run build) || exit 1
fi

# Frontend checks
if [ -d "frontend" ]; then
  echo "→ Frontend: type check"
  (cd frontend && bunx tsc --noEmit) || exit 1

  echo "→ Frontend: build"
  (cd frontend && bun run build) || exit 1
fi

# Full security checks (opt-in)
if [ "$FULL_PRE_PUSH" = "1" ]; then
  echo "→ Security: bun audit (backend-nestjs)"
  (cd backend-nestjs && bun audit) || true

  echo "→ Security: bun audit (backend-express)"
  (cd backend-express && bun audit) || true

  echo "→ Security: bun audit (frontend)"
  (cd frontend && bun audit) || true

  if command -v gitleaks > /dev/null 2>&1; then
    echo "→ Security: gitleaks full scan"
    gitleaks detect --verbose --redact || exit 1
  fi
fi

echo "✓ Pre-push checks passed"
