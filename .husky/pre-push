echo "Running pre-push checks..."

# Backend checks
if [ -d "backend" ]; then
  echo "→ Backend: type check"
  (cd backend && bunx tsc --noEmit) || exit 1

  echo "→ Backend: tests"
  (cd backend && bun test) || exit 1

  echo "→ Backend: build"
  (cd backend && bun run build) || exit 1
fi

# Frontend checks
if [ -d "frontend" ]; then
  echo "→ Frontend: type check"
  (cd frontend && bunx tsc --noEmit) || exit 1

  echo "→ Frontend: build"
  (cd frontend && bun run build) || exit 1
fi

# Full security checks (opt-in)
if [ "$FULL_PRE_PUSH" = "1" ]; then
  echo "→ Security: bun audit (backend)"
  (cd backend && bun audit) || true

  echo "→ Security: bun audit (frontend)"
  (cd frontend && bun audit) || true

  if command -v gitleaks > /dev/null 2>&1; then
    echo "→ Security: gitleaks full scan"
    gitleaks detect --verbose --redact || exit 1
  fi
fi

echo "✓ Pre-push checks passed"
