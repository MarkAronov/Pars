# Copy to .env and fill in values — same variables as backend-nestjs/.env.example,
# since both backends share the same repository/service layer and should point
# at the same database/storage for cross-backend parity testing.
#
# For a free-tier production deploy (no local Docker infra), the recommended
# providers are:
#   - Postgres: https://neon.tech (free tier, built-in pgvector support)
#   - MongoDB:  https://www.mongodb.com/atlas — create an M0 cluster (free forever)
#   - Storage:  https://developers.cloudflare.com/r2 (S3-compatible, free tier,
#               works with S3StorageProvider as-is — just different endpoint/keys)
# None of these accounts can be created on your behalf — sign up, then paste
# the resulting connection strings/keys in below (or as `fly secrets set` for
# a deployed instance, never committed to a real .env in git).

DATABASE_DRIVER=postgres                # or 'mongo' — picks the repository implementation

# --- Postgres (DATABASE_DRIVER=postgres) ---
# Local: postgresql://user:password@localhost:5432/pars_dev
# Neon:  paste the "Connection string" from the Neon dashboard (already includes
#        ?sslmode=require) — Neon's free tier has pgvector available out of the box.
DATABASE_URL=postgresql://user:password@localhost:5432/pars_dev

# --- MongoDB (DATABASE_DRIVER=mongo) ---
# Local: mongodb://localhost:27017/pars_dev?replicaSet=rs0
# Atlas: paste the "Connect your application" string from an M0 (free) cluster —
#        looks like mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/pars_dev
MONGO_URL=mongodb://localhost:27017/pars_dev?replicaSet=rs0

SESSION_SECRET=change-me-in-production-32-chars!!
CORS_ORIGIN=http://localhost:5173
REDIS_URL=redis://localhost:6379        # optional — defaults to localhost:6379

# --- Media storage ---
# STORAGE_DRIVER=local costs nothing and needs nothing below, but on Fly.io
# local disk isn't persistent/shared across machine restarts — fine for local
# dev, not recommended for a real deploy. STORAGE_DRIVER=s3 + Cloudflare R2
# credentials below is the free, persistent option.
STORAGE_DRIVER=local                    # or 's3' — defaults to 's3' if unset
BUCKET_NAME=                            # R2 bucket name
AWS_ENDPOINT_URL_S3=                    # R2: https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=                      # R2 API token access key id
AWS_SECRET_ACCESS_KEY=                  # R2 API token secret access key
S3_PUBLIC_URL=                          # R2 bucket's public URL (enable public access on the bucket first)

# --- Optional: real semantic search ---
OPENAI_API_KEY=                         # costs money per call — leave empty to skip

PORT=3001
