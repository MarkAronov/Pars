{
	"name": "pars-backend-express",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"author": "Mark Aronov",
	"keywords": [
		"express",
		"bun",
		"backend",
		"postgresql",
		"mongodb",
		"drizzle",
		"better-auth"
	],
	"scripts": {
		"dev": "bun run --watch src/main.ts",
		"build": "bun build src/main.ts --outdir dist --target bun",
		"start": "bun dist/main.js",
		"lint": "biome lint ./src",
		"format": "biome format ./src --write",
		"check": "biome check ./src",
		"check:fix": "biome check ./src --fix",
		"test": "vitest run",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.0",
		"@pars/db-adapters": "workspace:*",
		"argon2": "^0.43.0",
		"better-auth": "^1.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.0",
		"compression": "^1.8.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"drizzle-orm": "^0.43.0",
		"express": "^5.2.1",
		"file-type": "^22.0.1",
		"helmet": "^8.0.0",
		"mongodb": "^7.5.0",
		"multer": "^1.4.5-lts.1",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@testcontainers/mongodb": "^10.0.0",
		"@testcontainers/postgresql": "^10.0.0",
		"@types/compression": "^1.7.0",
		"@types/cookie-parser": "^1.4.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.0.0",
		"@types/supertest": "^7.2.0",
		"supertest": "^7.2.2",
		"testcontainers": "^10.0.0",
		"typescript": "~5.8.3",
		"vitest": "^3.0.0"
	}
}
