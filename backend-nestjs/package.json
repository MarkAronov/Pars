{
	"name": "pars-backend-nestjs",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"author": "Mark Aronov",
	"keywords": [
		"nestjs",
		"bun",
		"backend",
		"postgresql",
		"drizzle",
		"redis",
		"socket.io",
		"better-auth"
	],
	"scripts": {
		"dev": "bun run --watch src/main.ts",
		"build": "bun build src/main.ts --outdir dist --target bun --external mqtt --external amqp-connection-manager --external nats --external amqplib --external kafkajs --external 'class-transformer/storage'",
		"start": "bun dist/main.js",
		"lint": "biome lint ./src",
		"format": "biome format ./src --write",
		"check": "biome check ./src",
		"check:fix": "biome check ./src --fix",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"db:generate": "cd ../packages/db-adapters && bunx drizzle-kit generate",
		"db:migrate": "cd ../packages/db-adapters && bunx drizzle-kit migrate",
		"db:migrate:deploy": "cd ../packages/db-adapters && bunx drizzle-kit migrate",
		"db:studio": "cd ../packages/db-adapters && bunx drizzle-kit studio",
		"db:push": "cd ../packages/db-adapters && bunx drizzle-kit push"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1076.0",
		"@nestjs/common": "^11.0.0",
		"@nestjs/config": "^4.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/microservices": "^11.0.0",
		"@nestjs/platform-express": "^11.0.0",
		"@nestjs/platform-socket.io": "^11.0.0",
		"@nestjs/swagger": "^8.0.0",
		"@nestjs/throttler": "^6.0.0",
		"@nestjs/websockets": "^11.0.0",
		"@pars/db-adapters": "workspace:*",
		"@socket.io/redis-adapter": "^8.0.0",
		"argon2": "^0.43.0",
		"better-auth": "^1.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.0",
		"compression": "^1.8.0",
		"cookie-parser": "^1.4.7",
		"drizzle-orm": "^0.43.0",
		"express": "^5.2.1",
		"file-type": "^22.0.1",
		"helmet": "^8.0.0",
		"ioredis": "^5.0.0",
		"multer": "^1.4.5-lts.1",
		"postgres": "^3.4.5",
		"reflect-metadata": "^0.2.0",
		"rxjs": "^7.8.0",
		"socket.io": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@nestjs/testing": "^11.0.0",
		"@swc/core": "^1.15.43",
		"@testcontainers/postgresql": "^10.0.0",
		"@testcontainers/redis": "^10.0.0",
		"@types/compression": "^1.7.0",
		"@types/cookie-parser": "^1.4.0",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.0.0",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^3.0.0",
		"supertest": "^7.2.2",
		"testcontainers": "^10.0.0",
		"typescript": "~5.8.3",
		"unplugin-swc": "^1.5.9",
		"vite": "^7.0.0",
		"vitest": "^3.0.0"
	}
}