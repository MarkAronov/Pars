					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["pm.test('status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"]
							}
						}
					]
				}
			]
		},
		{
			"name": "Session Cleanup",
			"item": [
				{
					"name": "Sign Out",
					"request": {
						"method": "POST",
						"header": [{ "key": "Origin", "value": "{{corsOrigin}}" }],
						"url": "{{baseUrl}}/api/auth/sign-out"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"]
							}
						}
					],
					"description": "Kept in its own trailing folder rather than inside Auth — every other folder needs the session Auth > Sign In establishes, so signing out has to be the last thing that runs in a full top-to-bottom pass."
				}
			]
		}
	]
}
