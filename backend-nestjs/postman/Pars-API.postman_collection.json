{
	"info": {
		"name": "Pars API",
		"description": "Full API coverage for the Pars backend (backend-nestjs). Uses Postman's built-in cookie jar for session auth — run requests top-to-bottom within a folder (e.g. Auth > Sign Up, then Sign In) so the session cookie is set before hitting guarded endpoints. Collection variables (postId, threadId, topicId, userIdB, mediaId) are populated automatically by test scripts as you run through the requests, so later requests (Get Post, Patch Thread, etc.) can reference the IDs created earlier.\n\nNote: Topic create/patch/delete require a moderator/admin role, and there's no API endpoint to promote a user — you'll need to set `role` directly in the database for the signed-in user before those requests will succeed (they're included for completeness and will 403 otherwise, which is itself a useful check).\n\nMedia upload requests need a file attached manually in Postman's Body > form-data tab (`file` field) since collection JSON can't embed binary attachments.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000" },
		{ "key": "corsOrigin", "value": "http://localhost:5173" },
		{ "key": "userAEmail", "value": "" },
		{ "key": "userIdB", "value": "" },
		{ "key": "postId", "value": "" },
		{ "key": "topicId", "value": "" },
		{ "key": "threadId", "value": "" },
		{ "key": "mediaId", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Sign Up (User A)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Origin", "value": "{{corsOrigin}}" }
						],
						"url": "{{baseUrl}}/api/auth/sign-up/email",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user-a-{{$timestamp}}@example.com\",\n  \"password\": \"P@ssw0rd123!\",\n  \"name\": \"User A\"\n}"
						},
						"description": "Uses a timestamped email so the collection can be re-run against the same database without hitting a duplicate-email conflict."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"pm.test('has user id', () => pm.expect(pm.response.json().user).to.have.property('id'));",
									"if (pm.response.code === 200) pm.collectionVariables.set('userAEmail', pm.response.json().user.email);"
								]
							}
						}
					]
				},
				{
					"name": "Sign Up (User B)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Origin", "value": "{{corsOrigin}}" }
						],
						"url": "{{baseUrl}}/api/auth/sign-up/email",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user-b-{{$timestamp}}@example.com\",\n  \"password\": \"P@ssw0rd123!\",\n  \"name\": \"User B\"\n}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', () => pm.response.to.have.status(200));",
									"if (pm.response.code === 200) pm.collectionVariables.set('userIdB', pm.response.json().user.id);"
								]
							}
						}
					]
				},
				{
					"name": "Sign In (User A)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Origin", "value": "{{corsOrigin}}" }
						],
						"url": "{{baseUrl}}/api/auth/sign-in/email",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{userAEmail}}\",\n  \"password\": \"P@ssw0rd123!\"\n}"
						},
						"description": "Postman's cookie jar stores the session cookie automatically — subsequent requests to the same baseUrl are authenticated as User A until Sign Out or Sign In (User B) is run. Run Sign Up (User A) first so {{userAEmail}} is populated. The Origin header is required — better-auth rejects state-changing auth requests (sign-in/sign-out) without a trusted origin, and Postman doesn't send one by default like a browser would."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"]
							}
						}
					]
				},
				{
					"name": "Get Session",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/auth/get-session"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["pm.test('status is 200', () => pm.response.to.have.status(200));"]
							}
						}
					]
				}
			]
		},
