# Points the frontend at backend-express instead of backend-nestjs, for
# side-by-side comparison. Run via `bun run dev:express-backend`.
# Checked in directly (unlike .env.development) since nothing here is a
# secret — just a local port number.

VITE_API_BASE_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_GLITCHTIP_DSN=
