{
  "name": "pars-frontend",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pars",
    "react",
    "vite",
    "typescript",
    "frontend",
    "biome",
    "bun",
    "zustand",
    "tanstack-query"
  ],
  "author": "Mark Aronov",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src",
    "check:fix": "biome check ./src --fix",
    "check:format": "biome format ./src --check",
    "check:format:fix": "biome format ./src --check --write",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --reporter verbose --watch",
    "test:coverage": "vitest run --reporter verbose --coverage",
    "test:coverage:watch": "vitest --reporter verbose --coverage --watch",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "ui:update": "bunx shadcn@latest add --all --overwrite --yes",
    "stories:generate": "bun run ./scripts/generate-stories.ts",
    "stories:generate:force": "bun run ./scripts/generate-stories.ts --force",
    "lighthouse": "node ./scripts/lighthouse-run.cjs",
    "lighthouse:story": "node ./scripts/lighthouse-run.cjs http://localhost:6006",
    "lighthouse:dev": "node ./scripts/lighthouse-run.cjs http://localhost:5173",
    "axe": "node ./scripts/axe-run.cjs",
    "axe:story": "node ./scripts/axe-run.cjs http://localhost:6006",
    "axe:dev": "node ./scripts/axe-run.cjs http://localhost:5173",
    "clean": "git clean -fdxn",
    "clean:force": "git clean -fdx"
  },
  "dependencies": {
    "@biomejs/biome": "^2.1.3",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@tanstack/react-router": "^1.130.9",
    "@tanstack/react-router-devtools": "^1.130.9",
    "axios": "^1.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.11",
    "validator": "^13.15.15",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8",
    "@storybook/blocks": "^8",
    "@storybook/react": "^8",
    "@storybook/react-vite": "^8",
    "@tanstack/router-plugin": "^1.130.9",
    "@types/bun": "^1.2.19",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "globals": "^16.3.0",
    "storybook": "^8",
    "typescript": "~6.0.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  }
}