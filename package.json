{
    "name": "pars",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "backend-nestjs",
        "frontend",
        "packages/db-adapters",
        "packages/ui"
    ],
    "description": "Pars — a privacy-first social media platform",
    "author": "Mark Aronov",
    "license": "MIT",
    "scripts": {
        "prepare": "husky",
        "dev:backend-nestjs": "cd backend-nestjs && bun run dev",
        "dev:frontend": "cd frontend && bun run dev",
        "test:backend-nestjs": "cd backend-nestjs && bun test",
        "test:frontend": "cd frontend && bun test",
        "build:backend-nestjs": "cd backend-nestjs && bun run build",
        "build:frontend": "cd frontend && bun run build",
        "lint:backend-nestjs": "cd backend-nestjs && bun run lint",
        "lint:frontend": "cd frontend && bun run lint",
        "db:generate": "cd packages/db-adapters && bun run db:generate",
        "db:migrate": "cd packages/db-adapters && bun run db:migrate",
        "db:studio": "cd packages/db-adapters && bun run db:studio",
        "push:full": "FULL_PRE_PUSH=1 git push",
        "push:partial": "git commit --allow-empty -m 'chore: trigger partial CI [run-partial]' && git push",
        "security:gitleaks:docker": "docker run --rm -v \"$(pwd)\":/repo -w /repo ghcr.io/gitleaks/gitleaks:latest detect --verbose --redact",
        "security:trivy:docker": "docker run --rm -v \"$(pwd)\":/workspace aquasec/trivy:latest fs /workspace --severity CRITICAL,HIGH",
        "security:nuclei:docker": "docker run --rm -v \"$(pwd)/security/nuclei-templates\":/templates projectdiscovery/nuclei:latest -u http://host.docker.internal:3000 -t /templates -severity high,critical"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0"
    }
}